# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=Delphi
APP_ENV=development           # development | staging | production
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=DEBUG               # DEBUG | INFO | WARNING | ERROR

# ─── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./delphi.db

# ─── LLM Providers ────────────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
DEFAULT_LLM_PROVIDER=groq    # groq | openai
DEFAULT_MODEL=llama-3.3-70b-versatile

# ─── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Reputation ───────────────────────────────────────────────────────────────
STARTING_REPUTATION=1000.0
MIN_REPUTATION=700.0
MAX_REPUTATION=1300.0
REPUTATION_K_FACTOR=16.0
REFLECTION_FAILURE_THRESHOLD=70.0
REFLECTION_SUCCESS_THRESHOLD=80.0
RECOVERY_THRESHOLD=70.0
RECOVERY_LOOKBACK=5
REPUTATION_RECOVERY_THRESHOLD=950.0


